DATABASE_URL="file:./dev.db"
# Production: use Prisma Postgres — postgresql://... or prisma+postgres://...
# NEVER use file:./dev.db on Render (data is lost on restart).
PORT=4000
CLIENT_URL="https://shri-hari-jewels.vercel.app"
JWT_SECRET="change-this-to-a-long-random-string-in-production"

# Razorpay - enables automatic UPI payment detection (test keys from dashboard.razorpay.com)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Production example (Render):
# CLIENT_URL=""
# JWT_SECRET="<auto-generated by Render via render.yaml>"
