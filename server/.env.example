# Database (required for migrate / db push / running the API)
DATABASE_URL=postgresql://user:password@localhost:5432/shri_hari_jewels

# Direct Postgres URL for Prisma CLI (bypasses Supabase pooler on port 6543)
# Use the same value as DATABASE_URL for local dev; set to direct port 5432 for Supabase.
DIRECT_URL=postgresql://user:password@localhost:5432/shri_hari_jewels

# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Optional: extra CORS origins (comma-separated)
# CORS_EXTRA_ORIGINS=

# JWT (required in production — dev fallback exists but must be changed)
JWT_SECRET=change-me-in-production

# Optional: separate key for TOTP secret encryption (falls back to JWT_SECRET)
# TOTP_ENCRYPTION_KEY=

# Email (report delivery via SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Shri Hari Jewels <noreply@example.com>"

# Optional: disable scheduled jobs locally
# DISABLE_SCHEDULED_JOBS=true

# Optional: Sentry error tracking
# SENTRY_DSN=

# Optional: Razorpay payments
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Optional: live metal rates API
# METALS_API_KEY=

# Optional: cron overrides (defaults shown in server/src/jobs/scheduler.ts)
# RESERVATION_EXPIRY_CRON=*/5 * * * *
# INTEGRITY_REPORT_CRON=0 2 * * *
# RATE_FETCH_CRON=0 9 * * 1-6
# LEAD_REMINDER_CRON=*/15 * * * *

# Optional: pending sale reservation timeout in minutes
# PENDING_SALE_TIMEOUT_MINUTES=30

# Optional: log level (debug | info | warn | error)
# LOG_LEVEL=debug

# Optional: Tally Prime company name for XML export (must match Tally exactly)
# TALLY_COMPANY_NAME=Shree Hari Jewels
