enum LeadStage {
  New
  Qualification
  FollowUp     @map("Follow-up")
  Opportunity
  Quotation
  Won
  Lost
}

enum LeadSource {
  WalkIn        @map("Walk-in")
  Referral
  Phone
  WhatsApp
  Instagram
  Website
  Other
}

model Lead {
  id              String     @id @default(uuid())
  organizationId  String
