generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStockStatus {
  InStock    @map("In Stock")
  LowStock   @map("Low Stock")
  OutOfStock @map("Out of Stock")
}

enum InventoryUnitStatus {
  Available
  Reserved
  Sold
}

enum SalePaymentStatus {
  Pending
  Completed
}

enum OrderStatus {
  Pending
  Designing
  Production
  QC
  Ready
  Delivered
  Cancelled
}

enum OrderPaymentStatus {
  Unpaid
  Partial
  Paid
}

enum WorkOrderStatus {
  Open
  InProduction @map("In Production")
  QC
  Completed
  Cancelled
}

enum ProductionRunStatusEnum {
  Open
  InProgress @map("In Progress")
  Completed
  Cancelled
}

enum StoneLotStatus {
  InStock  @map("In Stock")
  Reserved
  Issued
}

model Branch {
  id          String   @id @default(uuid())
  name        String
  address     String?
  phone       String?
  email       String?
  manager     String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserBranch[]
  products    Product[]
  inventoryUnits InventoryUnit[]
  orders      Order[]
  workOrders      WorkOrder[]
  designs         Design[]
  productionRuns  ProductionRun[]
  motifs          Motif[]
  sales       Sale[]
  invoices    Invoice[]
  metalLots   MetalLot[]
  stoneLots   StoneLot[]
  stockTransfersFrom StockTransfer[] @relation("StockTransferFromBranch")
  stockTransfersTo   StockTransfer[] @relation("StockTransferToBranch")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      String
  active    Boolean  @default(true)
  defaultBranchId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches   UserBranch[]
  assignedWorkOrders WorkOrder[]
}

model UserBranch {
  id        String   @id @default(uuid())
  userId    String
  branchId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
}

model ShopSettings {
  id           String   @id @default("default")
  businessName String   @default("Shree Hari Jewels")
  address      String?
  phone        String?
  upiVpa       String?
  updatedAt    DateTime @updatedAt
}

model Product {
  id            String   @id @default(uuid())
  branchId      String
  sku           String   @unique
  name          String
  category      String
  metal         String
  purity        String
  weightGrams   Float
  makingCharges Decimal @db.Decimal(12, 2)
  stoneCarat    Float?
  price         Decimal @db.Decimal(12, 2)
  stock         Int
  status        ProductStockStatus
  imageColor    String   @default("#a1a1aa")
  productionRunId String? @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  units  InventoryUnit[]
  images ProductImage[]
  productionRun ProductionRun? @relation("ProductionRunFinishedGoods")

  @@index([branchId])
}

model InventoryUnit {
  id        String   @id @default(uuid())
  branchId  String
  itemCode  String   @unique
  productId String
  status    InventoryUnitStatus @default(Available)
  createdAt DateTime @default(now())

  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sale    Sale?

  @@index([productId])
  @@index([branchId])
}

model StockTransfer {
  id           String   @id @default(uuid())
  transferNo   String   @unique
  fromBranchId String
  toBranchId   String
  documentType String
  transferDate DateTime
  itemCount    Int
  totalValue   Decimal @db.Decimal(12, 2)
  createdById   String?
  createdByName String
  createdAt    DateTime @default(now())

  fromBranch Branch @relation("StockTransferFromBranch", fields: [fromBranchId], references: [id], onDelete: Cascade)
  toBranch   Branch @relation("StockTransferToBranch", fields: [toBranchId], references: [id], onDelete: Cascade)
  items      StockTransferItem[]

  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([createdAt])
  @@index([transferDate])
}

model StockTransferItem {
  id         String @id @default(uuid())
  transferId String
  itemCode   String
  productId  String
  productName String
  sku        String
  metal      String
  purity     String
  price      Decimal @db.Decimal(12, 2)

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
  @@index([itemCode])
  @@index([productId])
}

model Customer {
  id          String    @id @default(uuid())
  name        String
  mobile      String    @unique
  email       String?
  address     String?
  city        String?
  birthday    DateTime?
  anniversary DateTime?
  ringSize    String?
  preferences String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sales    Sale[]
  orders   Order[]
  invoices Invoice[]
}

model Order {
  id             String    @id @default(uuid())
  branchId       String
  orderNo        String    @unique
  customerId     String
  description    String
  estimatedTotal Decimal? @db.Decimal(12, 2)
  status         OrderStatus        @default(Pending)
  paymentStatus  OrderPaymentStatus @default(Unpaid)
  notes          String?
  dueDate        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrders WorkOrder[]

  @@index([customerId])
  @@index([branchId])
  @@index([status])
}

model Design {
  id                  String   @id @default(uuid())
  branchId            String
  code                String   @unique
  name                String?
  category            String?
  metal               String?
  purity              String?
  makingChargesPerSet Decimal? @db.Decimal(12, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  elements       DesignElement[]
  productionRuns ProductionRun[]

  @@index([branchId])
  @@index([category])
}

model DesignElement {
  id               String   @id @default(uuid())
  designId         String
  name             String
  type             String
  qtyPerSet        Int
  unitValue        Decimal? @db.Decimal(12, 2)
  weightGramsPerPc Float?
  sortOrder        Int      @default(0)

  design Design @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@index([designId])
}

model Motif {
  id          String   @id @default(uuid())
  branchId    String
  name        String
  description String?
  weightGrams Float?
  metal       String
  purity      String
  stone1      String?
  stone2      String?
  stone3      String?
  subCategory String
  price       Decimal? @db.Decimal(12, 2)
  imageUrl    String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, name, metal, purity])
  @@index([branchId])
  @@index([subCategory])
  @@index([metal])
  @@index([purity])
  @@index([name])
}

model ProductionRun {
  id          String   @id @default(uuid())
  branchId    String
  runNo       String   @unique
  designId    String
  setsOrdered Int
  status      ProductionRunStatusEnum @default(Open)
  finishedGoodsProductId String? @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  design Design              @relation(fields: [designId], references: [id], onDelete: Restrict)
  items  ProductionRunItem[]
  finishedGoodsProduct Product? @relation("ProductionRunFinishedGoods", fields: [finishedGoodsProductId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@index([designId])
  @@index([status])
}

model ProductionRunItem {
  id                  String    @id @default(uuid())
  productionRunId     String
  elementName         String
  elementType         String
  qtyPerSet           Int
  totalQty            Int
  unitValue           Decimal?  @db.Decimal(12, 2)
  weightGramsPerPc    Float?
  productionDate      DateTime?
  waxCount            Int?
  czStones            Int?
  czWeight            Float?
  castingReceived     Boolean   @default(false)
  metalLotId          String?
  stoneLotId          String?
  metalWeightGrams    Float?
  rawMaterialDeducted Boolean   @default(false)
  sortOrder           Int       @default(0)

  productionRun ProductionRun @relation(fields: [productionRunId], references: [id], onDelete: Cascade)

  @@index([productionRunId])
}

model WorkOrder {
  id            String   @id @default(uuid())
  branchId      String
  workOrderNo   String   @unique
  orderId       String?
  assignedToId  String?
  title         String
  description   String
  status        WorkOrderStatus @default(Open)
  priority      String   @default("Normal")
  dueDate       DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch     Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  order      Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  assignedTo User?  @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([assignedToId])
  @@index([branchId])
  @@index([status])
}

model Sale {
  id            String   @id @default(uuid())
  branchId      String
  unitId        String   @unique
  itemCode      String
  productId     String
  productName   String
  sku           String
  category      String
  listPrice     Decimal @db.Decimal(12, 2)
  discount      Decimal @default(0) @db.Decimal(12, 2)
  dealPrice     Decimal @db.Decimal(12, 2)
  paymentMode   String   @default("Cash")
  paymentStatus     SalePaymentStatus @default(Completed)
  paymentRef        String?
  razorpayQrId      String?
  razorpayPaymentId String?
  cartGroupId       String?
  customerId        String?
  customerPhone String
  customerName  String?
  soldAt        DateTime @default(now())

  branch   Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  unit     InventoryUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  customer Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoice  Invoice?

  @@index([soldAt])
  @@index([branchId])
  @@index([category])
  @@index([customerPhone])
  @@index([customerId])
  @@index([productId])
  @@index([paymentStatus])
  @@index([cartGroupId])
}

model Invoice {
  id             String   @id @default(uuid())
  branchId       String
  invoiceNo      String   @unique
  saleId         String   @unique
  customerId     String?
  customerName   String
  customerMobile String
  itemCode       String
  productName    String
  sku            String
  listPrice      Decimal @db.Decimal(12, 2)
  discount       Decimal @default(0) @db.Decimal(12, 2)
  total          Decimal @db.Decimal(12, 2)
  paymentMode    String
  paymentRef     String?
  status         String   @default("Paid")
  createdAt      DateTime @default(now())

  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sale     Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([branchId])
}

model ProductImage {
  id        String @id @default(uuid())
  productId String
  url       String
  name      String
  sortOrder Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model MetalLot {
  id           String   @id @default(uuid())
  branchId     String
  lotNumber    String   @unique
  metalType    String
  purity       String
  weightGrams  Float
  purchaseRate Decimal @db.Decimal(12, 2)
  currentRate  Decimal @db.Decimal(12, 2)
  vendor       String
  location     String   @default("Main Vault")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([metalType])
  @@index([location])
}

model StoneLot {
  id                String   @id @default(uuid())
  branchId          String
  certificateNumber String   @unique
  stoneType         String
  carat             Float
  color             String?
  clarity           String?
  cut               String?
  vendor            String
  purchaseRate      Decimal? @db.Decimal(12, 2)
  currentRate       Decimal? @db.Decimal(12, 2)
  location          String   @default("Main Vault")
  status            StoneLotStatus @default(InStock)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([stoneType])
  @@index([location])
  @@index([status])
}

model RawStockAuditLog {
  id              String   @id @default(uuid())
  stockType       String
  stockId         String
  lotRef          String
  action          String
  previousValue   String?
  newValue        String?
  fromLocation    String?
  toLocation      String?
  delta           Float?
  reason          String?
  performedById     String?
  performedByName   String
  createdAt       DateTime @default(now())

  @@index([stockType, stockId])
  @@index([createdAt])
}

model InventoryAuditLog {
  id              String   @id @default(uuid())
  entityType      String
  entityId        String
  productId       String?
  itemCode        String?
  action          String
  previousValue   String?
  newValue        String?
  reason          String?
  performedById   String?
  performedByName String
  createdAt       DateTime @default(now())

  @@index([entityType, entityId])
  @@index([productId])
  @@index([createdAt])
}

model SaleAuditLog {
  id              String   @id @default(uuid())
  saleId          String?
  invoiceId       String?
  action          String
  previousValue   String?
  newValue        String?
  reason          String?
  performedById   String?
  performedByName String
  createdAt       DateTime @default(now())

  @@index([saleId])
  @@index([invoiceId])
  @@index([createdAt])
}

model IntegrityMismatchLog {
  id         String   @id @default(uuid())
  category   String
  entityType String
  entityId   String?
  message    String
  expected   String?
  actual     String?
  createdAt  DateTime @default(now())

  @@index([category])
  @@index([createdAt])
}
