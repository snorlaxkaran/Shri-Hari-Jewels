generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Branch {
  id          String   @id @default(uuid())
  name        String
  address     String?
  phone       String?
  email       String?
  manager     String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserBranch[]
  products    Product[]
  inventoryUnits InventoryUnit[]
  orders      Order[]
  workOrders  WorkOrder[]
  sales       Sale[]
  invoices    Invoice[]
  metalLots   MetalLot[]
  stoneLots   StoneLot[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      String
  active    Boolean  @default(true)
  defaultBranchId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches   UserBranch[]
  assignedWorkOrders WorkOrder[]
}

model UserBranch {
  id        String   @id @default(uuid())
  userId    String
  branchId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
}

model ShopSettings {
  id           String   @id @default("default")
  businessName String   @default("Shree Hari Jewels")
  address      String?
  phone        String?
  upiVpa       String?
  updatedAt    DateTime @updatedAt
}

model Product {
  id            String   @id @default(uuid())
  branchId      String
  sku           String   @unique
  name          String
  category      String
  metal         String
  purity        String
  weightGrams   Float
  makingCharges Float
  stoneCarat    Float?
  price         Float
  stock         Int
  status        String
  imageColor    String   @default("#a1a1aa")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  units  InventoryUnit[]
  images ProductImage[]

  @@index([branchId])
}

model InventoryUnit {
  id        String   @id @default(uuid())
  branchId  String
  itemCode  String   @unique
  productId String
  status    String   @default("Available")
  createdAt DateTime @default(now())

  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sale    Sale?

  @@index([productId])
  @@index([branchId])
}

model Customer {
  id          String    @id @default(uuid())
  name        String
  mobile      String    @unique
  email       String?
  address     String?
  city        String?
  birthday    DateTime?
  anniversary DateTime?
  ringSize    String?
  preferences String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sales    Sale[]
  orders   Order[]
  invoices Invoice[]
}

model Order {
  id             String    @id @default(uuid())
  branchId       String
  orderNo        String    @unique
  customerId     String
  description    String
  estimatedTotal Float?
  status         String    @default("Pending")
  paymentStatus  String    @default("Unpaid")
  notes          String?
  dueDate        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrders WorkOrder[]

  @@index([customerId])
  @@index([branchId])
  @@index([status])
}

model WorkOrder {
  id            String   @id @default(uuid())
  branchId      String
  workOrderNo   String   @unique
  orderId       String?
  assignedToId  String?
  title         String
  description   String
  status        String   @default("Open")
  priority      String   @default("Normal")
  dueDate       DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch     Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  order      Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  assignedTo User?  @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([assignedToId])
  @@index([branchId])
  @@index([status])
}

model Sale {
  id            String   @id @default(uuid())
  branchId      String
  unitId        String   @unique
  itemCode      String
  productId     String
  productName   String
  sku           String
  category      String
  listPrice     Float
  discount      Float    @default(0)
  dealPrice     Float
  paymentMode   String   @default("Cash")
  paymentStatus     String   @default("Completed")
  paymentRef        String?
  razorpayQrId      String?
  razorpayPaymentId String?
  cartGroupId       String?
  customerId        String?
  customerPhone String
  customerName  String?
  soldAt        DateTime @default(now())

  branch   Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  unit     InventoryUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  customer Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoice  Invoice?

  @@index([soldAt])
  @@index([branchId])
  @@index([category])
  @@index([customerPhone])
  @@index([customerId])
  @@index([productId])
  @@index([paymentStatus])
  @@index([cartGroupId])
}

model Invoice {
  id             String   @id @default(uuid())
  branchId       String
  invoiceNo      String   @unique
  saleId         String   @unique
  customerId     String?
  customerName   String
  customerMobile String
  itemCode       String
  productName    String
  sku            String
  listPrice      Float
  discount       Float    @default(0)
  total          Float
  paymentMode    String
  paymentRef     String?
  status         String   @default("Paid")
  createdAt      DateTime @default(now())

  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sale     Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([branchId])
}

model ProductImage {
  id        String @id @default(uuid())
  productId String
  url       String
  name      String
  sortOrder Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model MetalLot {
  id           String   @id @default(uuid())
  branchId     String
  lotNumber    String   @unique
  metalType    String
  purity       String
  weightGrams  Float
  purchaseRate Float
  currentRate  Float
  vendor       String
  location     String   @default("Main Vault")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([metalType])
  @@index([location])
}

model StoneLot {
  id                String   @id @default(uuid())
  branchId          String
  certificateNumber String   @unique
  stoneType         String
  carat             Float
  color             String?
  clarity           String?
  cut               String?
  vendor            String
  purchaseRate      Float?
  currentRate       Float?
  location          String   @default("Main Vault")
  status            String   @default("In Stock")
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([stoneType])
  @@index([location])
  @@index([status])
}

model RawStockAuditLog {
  id              String   @id @default(uuid())
  stockType       String
  stockId         String
  lotRef          String
  action          String
  previousValue   String?
  newValue        String?
  fromLocation    String?
  toLocation      String?
  delta           Float?
  reason          String?
  performedById     String?
  performedByName   String
  createdAt       DateTime @default(now())

  @@index([stockType, stockId])
  @@index([createdAt])
}
