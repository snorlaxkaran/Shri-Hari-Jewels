  stockId         String
  lotRef          String
  action          String
  previousValue   String?
  newValue        String?
  fromLocation    String?
  toLocation      String?
  delta           Float?
  reason          String?
  performedById     String?
  performedByName   String
  createdAt       DateTime @default(now())

  @@index([stockType, stockId])
  @@index([createdAt])
}

model InventoryAuditLog {
