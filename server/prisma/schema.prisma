generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductStockStatus {
  InStock    @map("In Stock")
  LowStock   @map("Low Stock")
  OutOfStock @map("Out of Stock")
}

enum InventoryUnitStatus {
  Available
  Reserved
  Sold
  InTransit
  Transferred
  PendingVerification
}

enum EntryVoucherStatus {
  Pending
  Verified
}

enum StockTransferStatus {
  Pending
  Accepted
  Rejected
  PartiallyAccepted
}

enum SalePaymentStatus {
  Pending
  Completed
}

enum OrderStatus {
  Pending
  Designing
  Production
  QC
  Ready
  Delivered
  Cancelled
}

enum OrderPaymentStatus {
  Unpaid
  Partial
  Paid
}

enum WorkOrderStatus {
  Open
  InProduction @map("In Production")
  QC
  Completed
  Cancelled
}

enum ProductionRunStatusEnum {
  Open
  InProgress @map("In Progress")
  Completed
  Cancelled
}

enum CertifiedStoneLotStatus {
  InStock  @map("In Stock")
  Reserved
  Issued
}

enum StoneStockStatus {
  Active
  Depleted
  Closed
}

enum StoneRateBasis {
  Pcs
  Carat
}

enum StoneMovementType {
  Receipt
  Issue
  Return
  Breakage
  Loss
  Adjustment
}

enum StoneIssueStatus {
  Open
  Settled
}

enum StageLogAction {
  Started
  Completed
  Rejected
}

enum DesignApprovalStatus {
  Draft
  PendingApproval
  Approved
  Rejected
}

enum DesignBuilderStage {
  SKU         @map("SKU")
  CAD         @map("CAD")
  MoldMaking  @map("Mold Making")
  Motifs      @map("Motifs")
  Photo       @map("Photo")
  Complete    @map("Complete")
}

enum ProductionRunStage {
  WaxPattern      @map("Wax Pattern")
  Casting         @map("Casting")
  Cleaning        @map("Cleaning")
  Assembly        @map("Assembly")
  Prepolish       @map("Prepolish")
  StoneSetting    @map("Stone Setting")
  FinalPolishing  @map("Final Polishing")
  Plating         @map("Plating")
  QualityCheck    @map("Quality Check")
  Packaging       @map("Packaging")
}

enum WebOrderStatus {
  Pending
  Confirmed
  Processing
  Shipped
  Delivered
  Cancelled
}

enum WebOrderPaymentStatus {
  Unpaid
  Paid
  Refunded
}

enum RepairStatus {
  Received
  Estimated
  AwaitingApproval  @map("Awaiting Approval")
  Approved
  InProgress        @map("In Progress")
  QualityCheck      @map("Quality Check")
  ReadyForPickup    @map("Ready for Pickup")
  Delivered
  Rejected
  Cancelled
}

model Organization {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  emailDomain  String?
  customDomain String?  @unique
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branches            Branch[]
  users               User[]
  shopSettings        ShopSettings?
  storefrontSettings  StorefrontSettings?
  storefrontCollections StorefrontCollection[]
  webOrders           WebOrder[]
  customers           Customer[]
  leads               Lead[]
  stoneTypes          StoneType[]
  designs             Design[]
  products            Product[]
  inventoryUnits      InventoryUnit[]
  productionRuns      ProductionRun[]
  entryVouchers       EntryVoucher[]
  repairOrders        RepairOrder[]
  vendors             Vendor[]
  purchaseBills       PurchaseBill[]
  tallyExportLogs     TallyExportLog[]
}

model StorefrontSettings {
  id             String   @id @default(uuid())
  organizationId String   @unique
  enabled        Boolean  @default(false)
  tagline        String?
  heroTitle      String?
  heroSubtitle   String?
  aboutText      String?  @db.Text
  primaryColor   String   @default("#b8860b")
  accentColor    String   @default("#1a1a1a")
  logoUrl        String?
  bannerUrl      String?
  contactEmail   String?
  contactPhone   String?
  instagramUrl   String?
  facebookUrl    String?
  whatsappNumber String?
  shippingNote   String?  @db.Text
  returnPolicy   String?  @db.Text
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model StorefrontCollection {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  slug           String
  description    String?  @db.Text
  imageUrl       String?
  sortOrder      Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     StorefrontCollectionProduct[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model StorefrontCollectionProduct {
  id           String @id @default(uuid())
  collectionId String
  productId    String
  sortOrder    Int    @default(0)

  collection StorefrontCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    Product              @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@index([collectionId])
  @@index([productId])
}

model WebOrder {
  id             String                @id @default(uuid())
  organizationId String
  branchId       String
  orderNo        String
  customerId     String?
  customerName   String
  customerEmail  String?
  customerMobile String
  addressLine1   String
  addressLine2   String?
  city           String
  state          String
  pincode        String
  country        String                @default("India")
  status         WebOrderStatus        @default(Pending)
  paymentStatus  WebOrderPaymentStatus @default(Unpaid)
  totalAmount    Decimal               @db.Decimal(12, 2)
  notes          String?
  erpOrderId     String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items        WebOrderItem[]

  @@unique([organizationId, orderNo])
  @@index([organizationId])
  @@index([branchId])
  @@index([status])
  @@index([createdAt])
}

model WebOrderItem {
  id          String  @id @default(uuid())
  webOrderId  String
  productId   String
  productSku  String
  productName String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(12, 2)
  lineTotal   Decimal @db.Decimal(12, 2)
  reservedUnitIds Json @default("[]")

  webOrder WebOrder @relation(fields: [webOrderId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([webOrderId])
  @@index([productId])
}

model Branch {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  address        String?
  phone          String?
  email          String?
  manager        String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users       UserBranch[]
  products    Product[]
  inventoryUnits InventoryUnit[]
  orders      Order[]
  workOrders      WorkOrder[]
  designs         Design[]
  productionRuns  ProductionRun[]
  motifs          Motif[]
  sales       Sale[]
  invoices    Invoice[]
  metalLots   MetalLot[]
  certifiedStoneLots CertifiedStoneLot[]
  stoneStocks        StoneStock[]
  stoneStockMovements StoneStockMovement[]
  stoneIssues ProductionRunStoneIssue[]
  metalIssues ProductionRunMetalIssue[]
  stockTransfersFrom StockTransfer[] @relation("StockTransferFromBranch")
  stockTransfersTo   StockTransfer[] @relation("StockTransferToBranch")
  customerBranches   CustomerBranch[]
  entryVouchers      EntryVoucher[]
  webOrders          WebOrder[]
  leads              Lead[]
  leadAppointments   Appointment[]
  repairOrders       RepairOrder[]
  purchaseBills      PurchaseBill[]

  @@index([organizationId])
}

model User {
  id                   String    @id @default(uuid())
  organizationId       String?
  email                String    @unique
  name                 String
  password             String
  role                 String
  active               Boolean   @default(true)
  defaultBranchId      String?
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  totpSecret           String?
  totpEnabled          Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branches       UserBranch[]
  assignedWorkOrders WorkOrder[]
  refreshTokens  RefreshToken[]
  notifications  Notification[]

  @@index([organizationId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UserBranch {
  id        String   @id @default(uuid())
  userId    String
  branchId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
}

model ShopSettings {
  id             String   @id @default(uuid())
  organizationId String   @unique
  businessName   String   @default("Jewellery Business")
  address      String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  pincode      String?
  country      String?  @default("India")
  phone        String?
  email        String?
  upiVpa       String?
  panNumber    String?
  gstNumber    String?
  cinNumber    String?
  gstRegisteredName String?
  goldHsnCode       String? @default("7113")
  silverHsnCode     String? @default("7113")
  imitationHsnCode  String? @default("71179010")
  invoiceTerms             String?
  registeredOfficeAddress  String?
  bankAccountName   String?
  bankAccountNumber String?
  bankIfsc          String?
  bankName          String?
  goldMakingChargesPct           Decimal  @default(17.00) @db.Decimal(5, 2)
  silverMakingChargesPct         Decimal  @default(17.00) @db.Decimal(5, 2)
  makingChargesOverrideNote      String?
  discountApprovalThresholdPct   Decimal  @default(10.00) @db.Decimal(5, 2)
  onboardingCompletedAt          DateTime?
  updatedAt                      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Product {
  id             String   @id @default(uuid())
  organizationId String
  branchId       String
  sku            String
  name          String
  category      String
  metal         String
  purity        String
  weightGrams   Float
  makingCharges Decimal @db.Decimal(12, 2)
  stoneCarat    Float?
  price         Decimal @db.Decimal(12, 2)
  stock         Int
  status        ProductStockStatus
  imageColor              String   @default("#a1a1aa")
  publishedToStorefront   Boolean  @default(false)
  storefrontDescription   String?  @db.Text
  productionRunId         String?  @unique
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  units        InventoryUnit[]
  images       ProductImage[]
  productionRun ProductionRun? @relation("ProductionRunFinishedGoods")
  collectionLinks StorefrontCollectionProduct[]
  webOrderItems   WebOrderItem[]

  @@unique([organizationId, sku])
  @@index([branchId])
  @@index([organizationId])
}

model InventoryUnit {
  id             String   @id @default(uuid())
  organizationId String
  branchId       String
  itemCode       String
  productId      String
  status         InventoryUnitStatus @default(Available)
  listPrice      Decimal? @db.Decimal(12, 2)
  hallmarkNumber String?
  hallmarkCenter String?
  voucherId             String?
  branchTransferredAt   DateTime?
  createdAt             DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  entryVoucher EntryVoucher? @relation(fields: [voucherId], references: [id], onDelete: SetNull)
  sale         Sale?

  @@unique([organizationId, itemCode])
  @@index([productId])
  @@index([branchId])
  @@index([organizationId])
  @@index([voucherId])
}

model EntryVoucher {
  id               String              @id @default(uuid())
  organizationId   String
  branchId         String
  voucherCode      String
  createdByUserId  String?
  createdByName    String
  createdAt        DateTime            @default(now())
  verifiedAt       DateTime?
  verifiedByUserId String?
  verifiedByName   String?
  status           EntryVoucherStatus  @default(Pending)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  units        InventoryUnit[]
  purchaseBill PurchaseBill?

  @@unique([organizationId, voucherCode])
  @@index([organizationId, status])
  @@index([branchId])
  @@index([createdAt])
}

model StockTransfer {
  id           String   @id @default(uuid())
  transferNo   String   @unique
  fromBranchId String
  toBranchId   String
  customerId        String?
  customerBranchId  String?
  documentType String
  transferDate DateTime
  itemCount    Int
  totalValue   Decimal @db.Decimal(12, 2)
  status          StockTransferStatus @default(Pending)
  acceptedById    String?
  acceptedByName  String?
  acceptedAt      DateTime?
  rejectionReason String?
  notes           String?
  recipientGstNumber         String?
  recipientGstRegisteredName String?
  recipientPanNumber         String?
  recipientEmail             String?
  recipientPhone             String?
  recipientAddress           String?
  placeOfSupplyState         String?
  placeOfSupplyStateCode     String?
  placeOfDeliveryState       String?
  placeOfDeliveryStateCode   String?
  contactPersonName  String?
  contactPersonPhone String?
  courierCompany     String?
  dispatchDate       DateTime?
  invoiceNo          String?
  invoicedAt         DateTime?
  createdById   String?
  createdByName String
  createdAt    DateTime @default(now())

  fromBranch     Branch          @relation("StockTransferFromBranch", fields: [fromBranchId], references: [id], onDelete: Cascade)
  toBranch       Branch          @relation("StockTransferToBranch", fields: [toBranchId], references: [id], onDelete: Cascade)
  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerBranch CustomerBranch? @relation(fields: [customerBranchId], references: [id], onDelete: SetNull)
  items      StockTransferItem[]

  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([customerId])
  @@index([customerBranchId])
  @@index([status])
  @@index([toBranchId, status])
  @@index([createdAt])
  @@index([transferDate])
}

model StockTransferItem {
  id         String @id @default(uuid())
  transferId String
  itemCode   String
  productId  String
  productName String
  sku        String
  metal      String
  purity     String
  price      Decimal @db.Decimal(12, 2)
  accepted   Boolean @default(true)
  weightGrams  Decimal? @db.Decimal(10, 3)

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
  @@index([itemCode])
  @@index([productId])
}

model Customer {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  mobile         String
  companyName       String?
  ownerName         String?
  contactPersonName String?
  customerType      String  @default("Individual Buyer")
  email       String?
  address     String?
  city        String?
  billingAddressLine1 String?
  billingAddressLine2 String?
  billingCity         String?
  billingState        String?
  billingPincode      String?
  billingCountry      String?  @default("India")
  panNumber           String?
  gstNumber           String?
  gstRegisteredName   String?
  bankAccountName     String?
  bankAccountNumber   String?
  bankIfsc            String?
  bankName            String?
  birthday    DateTime?
  anniversary DateTime?
  ringSize    String?
  preferences String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sales    Sale[]
  orders   Order[]
  invoices Invoice[]
  branches CustomerBranch[]
  deptContacts CustomerDepartmentContact[]
  stockTransfers StockTransfer[]
  exchangeTransactions ExchangeTransaction[]
  schemeEnrollments    SchemeEnrollment[]
  webOrders            WebOrder[]
  leads                Lead[]
  repairOrders         RepairOrder[]

  @@unique([organizationId, mobile])
  @@index([organizationId])
}

model CustomerDepartmentContact {
  id              String   @id @default(uuid())
  customerId      String
  department      String
  personName      String
  email           String?
  phone           String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model CustomerBranch {
  id         String   @id @default(uuid())
  customerId String
  branchId   String?
  name       String
  officeType String   @default("Branch Office")
  address    String?
  city       String?
  state      String?
  pincode    String?
  gstNumber         String?
  gstRegisteredName String?
  panNumber         String?
  email             String?
  phone             String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer       Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  linkedBranch   Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  stockTransfers StockTransfer[]

  @@index([customerId])
  @@index([branchId])
  @@index([customerId, active])
}

model Order {
  id             String    @id @default(uuid())
  branchId       String
  orderNo        String    @unique
  customerId     String
  description    String
  estimatedTotal Decimal? @db.Decimal(12, 2)
  status         OrderStatus        @default(Pending)
  paymentStatus  OrderPaymentStatus @default(Unpaid)
  notes          String?
  dueDate        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrders WorkOrder[]

  @@index([customerId])
  @@index([branchId])
  @@index([status])
}

model Design {
  id                  String   @id @default(uuid())
  organizationId      String
  branchId            String
  code                String
  name                String?
  category            String?
  metal               String?
  purity              String?
  makingChargesPerSet Decimal? @db.Decimal(12, 2)
  builderStage        DesignBuilderStage @default(SKU)
  cadReady            Boolean  @default(false)
  cadNotes            String?
  cadFileUrl          String?  @db.Text
  cadCompletedAt      DateTime?
  moldNotes           String?
  moldPhotoUrl        String?  @db.Text
  moldCompletedAt     DateTime?
  finishedPhotoUrl    String?  @db.Text
  finishedPhotoUrls   String[] @default([])
  builderCompletedAt  DateTime?
  approvalStatus      DesignApprovalStatus @default(Draft)
  approvedById        String?
  approvedByName      String?
  approvedAt          DateTime?
  rejectionReason     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  elements       DesignElement[]
  productionRuns ProductionRun[]

  @@unique([organizationId, code])
  @@index([branchId])
  @@index([organizationId])
  @@index([category])
  @@index([builderStage])
}

model DesignElement {
  id               String   @id @default(uuid())
  designId         String
  motifId          String?
  name             String
  type             String
  qtyPerSet        Int
  unitValue        Decimal? @db.Decimal(12, 2)
  weightGramsPerPc Float?
  sortOrder        Int      @default(0)

  design Design @relation(fields: [designId], references: [id], onDelete: Cascade)
  motif  Motif? @relation(fields: [motifId], references: [id], onDelete: SetNull)

  @@index([designId])
  @@index([motifId])
}

model Motif {
  id          String   @id @default(uuid())
  branchId    String
  name        String
  description String?
  weightGrams Float?
  metal       String
  purity      String
  /// @deprecated Use MotifStone rows instead. Kept for migration; will be removed in a follow-up.
  stone1      String?
  /// @deprecated Use MotifStone rows instead. Kept for migration; will be removed in a follow-up.
  stone2      String?
  /// @deprecated Use MotifStone rows instead. Kept for migration; will be removed in a follow-up.
  stone3      String?
  subCategory String
  makingCost  Decimal? @db.Decimal(12, 2)
  price       Decimal? @db.Decimal(12, 2)
  imageUrl    String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  stones         MotifStone[]
  designElements DesignElement[]

  @@unique([branchId, name, metal, purity])
  @@index([branchId])
  @@index([subCategory])
  @@index([metal])
  @@index([purity])
  @@index([name])
}

model MotifStone {
  id          String @id @default(uuid())
  motifId     String
  stoneType   String
  qtyPerMotif Int
  sortOrder   Int    @default(0)

  motif Motif @relation(fields: [motifId], references: [id], onDelete: Cascade)

  @@index([motifId])
  @@index([stoneType])
}

model ProductionRun {
  id             String   @id @default(uuid())
  organizationId String
  branchId       String
  runNo          String
  designId    String
  setsOrdered Int
  status      ProductionRunStatusEnum @default(Open)
  currentStage ProductionRunStage @default(WaxPattern)
  finishedGoodsProductId String? @unique
  metalInventoryDeducted Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  design       Design                @relation(fields: [designId], references: [id], onDelete: Restrict)
  items        ProductionRunItem[]
  stageLogs    ProductionRunStageLog[]
  stoneIssues  ProductionRunStoneIssue[]
  metalIssues  ProductionRunMetalIssue[]
  finishedGoodsProduct Product? @relation("ProductionRunFinishedGoods", fields: [finishedGoodsProductId], references: [id], onDelete: SetNull)

  @@unique([organizationId, runNo])
  @@index([branchId])
  @@index([organizationId])
  @@index([designId])
  @@index([status])
  @@index([currentStage])
}

model ProductionRunStageLog {
  id              String   @id @default(uuid())
  productionRunId String
  stage           ProductionRunStage
  action          StageLogAction @default(Started)
  karigarName     String?
  notes           String?
  rejectionReason String?
  rejectedToStage ProductionRunStage?
  performedById   String?
  performedByName String
  createdAt       DateTime @default(now())

  productionRun ProductionRun @relation(fields: [productionRunId], references: [id], onDelete: Cascade)

  @@index([productionRunId])
  @@index([stage])
  @@index([createdAt])
}

model ProductionRunItem {
  id                  String    @id @default(uuid())
  productionRunId     String
  elementName         String
  elementType         String
  qtyPerSet           Int
  totalQty            Int
  unitValue           Decimal?  @db.Decimal(12, 2)
  weightGramsPerPc    Float?
  productionDate      DateTime?
  waxCount            Int?
  czStones            Int?
  czWeight            Float?
  castingReceived     Boolean   @default(false)
  metalLotId          String?
  stoneLotId          String?
  metalWeightGrams    Float?
  rawMaterialDeducted Boolean   @default(false)
  stoneOrderDate      DateTime?
  stoneDeliveryDate   DateTime?
  stoneSignOff        String?
  sortOrder           Int       @default(0)
  motifId             String?
  imageUrl            String?   @db.Text
  stageCheckoffs      Json      @default("{}")

  productionRun ProductionRun @relation(fields: [productionRunId], references: [id], onDelete: Cascade)

  @@index([productionRunId])
}

model WorkOrder {
  id            String   @id @default(uuid())
  branchId      String
  workOrderNo   String   @unique
  orderId       String?
  assignedToId  String?
  title         String
  description   String
