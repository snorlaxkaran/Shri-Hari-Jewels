generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductStockStatus {
  InStock    @map("In Stock")
  LowStock   @map("Low Stock")
  OutOfStock @map("Out of Stock")
}

enum InventoryUnitStatus {
  Available
  Reserved
  Sold
  InTransit
}

enum StockTransferStatus {
  Pending
  Accepted
  Rejected
  PartiallyAccepted
}

enum SalePaymentStatus {
  Pending
  Completed
}

enum OrderStatus {
  Pending
  Designing
  Production
  QC
  Ready
  Delivered
  Cancelled
}

enum OrderPaymentStatus {
  Unpaid
  Partial
  Paid
}

enum WorkOrderStatus {
  Open
  InProduction @map("In Production")
  QC
  Completed
  Cancelled
}

enum ProductionRunStatusEnum {
  Open
  InProgress @map("In Progress")
  Completed
  Cancelled
}

enum CertifiedStoneLotStatus {
  InStock  @map("In Stock")
  Reserved
  Issued
}

enum StoneCategory {
  CZ
  Diamond
  Precious
  SemiPrecious
}

enum StoneOriginType {
  Natural
  LabGrown
  Synthetic
}

enum StoneUOM {
  Pcs
  Carat
}

enum StoneShape {
  Round
  Oval
  Pear
  Princess
  Cushion
  Emerald
  Marquise
  Heart
  Baguette
  Trillion
  Asscher
  Radiant
  Hexagon
  Octagon
  Cabochon
}

enum StonePurchaseLotStatus {
  Active
  Depleted
  Closed
}

enum StoneMovementType {
  Receipt
  Issue
  Return
  Breakage
  Loss
  Adjustment
}

enum StoneIssueStatus {
  Open
  Settled
}

enum DesignBuilderStage {
  SKU         @map("SKU")
  CAD         @map("CAD")
  MoldMaking  @map("Mold Making")
  Motifs      @map("Motifs")
  Photo       @map("Photo")
  Complete    @map("Complete")
}

enum ProductionRunStage {
  WaxPattern      @map("Wax Pattern")
  Casting         @map("Casting")
  Cleaning        @map("Cleaning")
  Assembly        @map("Assembly")
  Prepolish       @map("Prepolish")
  StoneSetting    @map("Stone Setting")
  FinalPolishing  @map("Final Polishing")
  Plating         @map("Plating")
  QualityCheck    @map("Quality Check")
  Packaging       @map("Packaging")
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  emailDomain String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branches       Branch[]
  users          User[]
  shopSettings   ShopSettings?
  customers      Customer[]
  stoneMasters   StoneMaster[]
  designs        Design[]
  products       Product[]
  inventoryUnits InventoryUnit[]
  productionRuns ProductionRun[]
}

model Branch {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  address        String?
  phone          String?
  email          String?
  manager        String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users       UserBranch[]
  products    Product[]
  inventoryUnits InventoryUnit[]
  orders      Order[]
  workOrders      WorkOrder[]
  designs         Design[]
  productionRuns  ProductionRun[]
  motifs          Motif[]
  sales       Sale[]
  invoices    Invoice[]
  metalLots   MetalLot[]
  certifiedStoneLots CertifiedStoneLot[]
  stoneLots   StoneLot[]
  stoneMovements StoneMovement[]
  stoneIssues ProductionRunStoneIssue[]
  bulkStoneLots BulkStoneLot[]
  stockTransfersFrom StockTransfer[] @relation("StockTransferFromBranch")
  stockTransfersTo   StockTransfer[] @relation("StockTransferToBranch")
  customerBranches   CustomerBranch[]

  @@index([organizationId])
}

model User {
  id              String   @id @default(uuid())
  organizationId  String?
  email           String   @unique
  name            String
  password        String
  role            String
  active          Boolean  @default(true)
  defaultBranchId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branches   UserBranch[]
  assignedWorkOrders WorkOrder[]

  @@index([organizationId])
}

model UserBranch {
  id        String   @id @default(uuid())
  userId    String
  branchId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
}

model ShopSettings {
  id             String   @id @default(uuid())
  organizationId String   @unique
  businessName   String   @default("Jewellery Business")
  address      String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  pincode      String?
  country      String?  @default("India")
  phone        String?
  upiVpa       String?
  panNumber    String?
  gstNumber    String?
  gstRegisteredName String?
  bankAccountName   String?
  bankAccountNumber String?
  bankIfsc          String?
  bankName          String?
  goldMakingChargesPct      Decimal @default(17.00) @db.Decimal(5, 2)
  silverMakingChargesPct    Decimal @default(17.00) @db.Decimal(5, 2)
  makingChargesOverrideNote String?
  updatedAt    DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Product {
  id             String   @id @default(uuid())
  organizationId String
  branchId       String
  sku            String
  name          String
  category      String
  metal         String
  purity        String
  weightGrams   Float
  makingCharges Decimal @db.Decimal(12, 2)
  stoneCarat    Float?
  price         Decimal @db.Decimal(12, 2)
  stock         Int
  status        ProductStockStatus
  imageColor    String   @default("#a1a1aa")
  productionRunId String? @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  units        InventoryUnit[]
  images       ProductImage[]
  productionRun ProductionRun? @relation("ProductionRunFinishedGoods")

  @@unique([organizationId, sku])
  @@index([branchId])
  @@index([organizationId])
}

model InventoryUnit {
  id             String   @id @default(uuid())
  organizationId String
  branchId       String
  itemCode       String
  productId      String
  status    InventoryUnitStatus @default(Available)
  listPrice Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  sale         Sale?

  @@unique([organizationId, itemCode])
  @@index([productId])
  @@index([branchId])
  @@index([organizationId])
}

model StockTransfer {
  id           String   @id @default(uuid())
  transferNo   String   @unique
  fromBranchId String
  toBranchId   String
  customerId        String?
  customerBranchId  String?
  documentType String
  transferDate DateTime
  itemCount    Int
  totalValue   Decimal @db.Decimal(12, 2)
  status          StockTransferStatus @default(Pending)
  acceptedById    String?
  acceptedByName  String?
  acceptedAt      DateTime?
  rejectionReason String?
  notes           String?
  recipientGstNumber         String?
  recipientGstRegisteredName String?
  recipientPanNumber         String?
  recipientEmail             String?
  recipientPhone             String?
  recipientAddress           String?
  placeOfSupplyState         String?
  placeOfSupplyStateCode     String?
  placeOfDeliveryState       String?
  placeOfDeliveryStateCode   String?
  createdById   String?
  createdByName String
  createdAt    DateTime @default(now())

  fromBranch     Branch          @relation("StockTransferFromBranch", fields: [fromBranchId], references: [id], onDelete: Cascade)
  toBranch       Branch          @relation("StockTransferToBranch", fields: [toBranchId], references: [id], onDelete: Cascade)
  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerBranch CustomerBranch? @relation(fields: [customerBranchId], references: [id], onDelete: SetNull)
  items      StockTransferItem[]

  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([customerId])
  @@index([customerBranchId])
  @@index([status])
  @@index([toBranchId, status])
  @@index([createdAt])
  @@index([transferDate])
}

model StockTransferItem {
  id         String @id @default(uuid())
  transferId String
  itemCode   String
  productId  String
  productName String
  sku        String
  metal      String
  purity     String
  price      Decimal @db.Decimal(12, 2)
  accepted   Boolean @default(true)

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
  @@index([itemCode])
  @@index([productId])
}

model Customer {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  mobile         String
  email       String?
  address     String?
  city        String?
  billingAddressLine1 String?
  billingAddressLine2 String?
  billingCity         String?
  billingState        String?
  billingPincode      String?
  billingCountry      String?  @default("India")
  panNumber           String?
  gstNumber           String?
  gstRegisteredName   String?
  bankAccountName     String?
  bankAccountNumber   String?
  bankIfsc            String?
  bankName            String?
  birthday    DateTime?
  anniversary DateTime?
  ringSize    String?
  preferences String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sales    Sale[]
  orders   Order[]
  invoices Invoice[]
  branches CustomerBranch[]
  stockTransfers StockTransfer[]

  @@unique([organizationId, mobile])
  @@index([organizationId])
}

model CustomerBranch {
  id         String   @id @default(uuid())
  customerId String
  branchId   String?
  name       String
  address    String?
  city       String?
  state      String?
  pincode    String?
  gstNumber         String?
  gstRegisteredName String?
  panNumber         String?
  email             String?
  phone             String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer       Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  linkedBranch   Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  stockTransfers StockTransfer[]

  @@index([customerId])
  @@index([branchId])
  @@index([customerId, active])
}

model Order {
  id             String    @id @default(uuid())
  branchId       String
  orderNo        String    @unique
  customerId     String
  description    String
  estimatedTotal Decimal? @db.Decimal(12, 2)
  status         OrderStatus        @default(Pending)
  paymentStatus  OrderPaymentStatus @default(Unpaid)
  notes          String?
  dueDate        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrders WorkOrder[]

  @@index([customerId])
  @@index([branchId])
  @@index([status])
}

model Design {
  id                  String   @id @default(uuid())
  organizationId      String
  branchId            String
  code                String
  name                String?
  category            String?
  metal               String?
  purity              String?
  makingChargesPerSet Decimal? @db.Decimal(12, 2)
  builderStage        DesignBuilderStage @default(SKU)
  cadFileUrl          String?  @db.Text
  cadCompletedAt      DateTime?
  moldNotes           String?
  moldPhotoUrl        String?  @db.Text
  moldCompletedAt     DateTime?
  finishedPhotoUrl    String?  @db.Text
  finishedPhotoUrls   String[] @default([])
  builderCompletedAt  DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  elements       DesignElement[]
  productionRuns ProductionRun[]

  @@unique([organizationId, code])
  @@index([branchId])
  @@index([organizationId])
  @@index([category])
  @@index([builderStage])
}

model DesignElement {
  id               String   @id @default(uuid())
  designId         String
  motifId          String?
  name             String
  type             String
  qtyPerSet        Int
  unitValue        Decimal? @db.Decimal(12, 2)
  weightGramsPerPc Float?
  sortOrder        Int      @default(0)

  design Design @relation(fields: [designId], references: [id], onDelete: Cascade)
  motif  Motif? @relation(fields: [motifId], references: [id], onDelete: SetNull)

  @@index([designId])
  @@index([motifId])
}

model Motif {
  id          String   @id @default(uuid())
  branchId    String
  name        String
  description String?
  weightGrams Float?
  metal       String
  purity      String
  /// @deprecated Use MotifStone rows instead. Kept for migration; will be removed in a follow-up.
  stone1      String?
  /// @deprecated Use MotifStone rows instead. Kept for migration; will be removed in a follow-up.
  stone2      String?
  /// @deprecated Use MotifStone rows instead. Kept for migration; will be removed in a follow-up.
  stone3      String?
  subCategory String
  makingCost  Decimal? @db.Decimal(12, 2)
  price       Decimal? @db.Decimal(12, 2)
  imageUrl    String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  stones         MotifStone[]
  designElements DesignElement[]

  @@unique([branchId, name, metal, purity])
  @@index([branchId])
  @@index([subCategory])
  @@index([metal])
  @@index([purity])
  @@index([name])
}

model BulkStoneLot {
  id            String    @id @default(uuid())
  branchId      String
  sizeLabel     String
  stoneType     String
  quantity      Int
  pricePerStone Decimal   @db.Decimal(12, 4)
  vendor        String?
  lotReference  String?
  purchaseDate  DateTime?
  location      String    @default("Main Vault")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  branch      Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([stoneType])
  @@index([sizeLabel])
}

model MotifStone {
  id             String @id @default(uuid())
  motifId        String
  stoneMasterId  String
  qtyPerMotif    Int
  sortOrder      Int    @default(0)

  motif       Motif       @relation(fields: [motifId], references: [id], onDelete: Cascade)
  stoneMaster StoneMaster @relation(fields: [stoneMasterId], references: [id], onDelete: Restrict)

  @@index([motifId])
  @@index([stoneMasterId])
}

model ProductionRun {
  id             String   @id @default(uuid())
  organizationId String
  branchId       String
  runNo          String
  designId    String
  setsOrdered Int
  status      ProductionRunStatusEnum @default(Open)
  currentStage ProductionRunStage @default(WaxPattern)
  finishedGoodsProductId String? @unique
  metalInventoryDeducted Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  design       Design                @relation(fields: [designId], references: [id], onDelete: Restrict)
  items        ProductionRunItem[]
  stageLogs    ProductionRunStageLog[]
  stoneIssues  ProductionRunStoneIssue[]
  finishedGoodsProduct Product? @relation("ProductionRunFinishedGoods", fields: [finishedGoodsProductId], references: [id], onDelete: SetNull)

  @@unique([organizationId, runNo])
  @@index([branchId])
  @@index([organizationId])
  @@index([designId])
  @@index([status])
  @@index([currentStage])
}

model ProductionRunStageLog {
  id              String   @id @default(uuid())
  productionRunId String
  stage           ProductionRunStage
  notes           String?
  performedById   String?
  performedByName String
  createdAt       DateTime @default(now())

  productionRun ProductionRun @relation(fields: [productionRunId], references: [id], onDelete: Cascade)

  @@index([productionRunId])
  @@index([stage])
  @@index([createdAt])
}

model ProductionRunItem {
  id                  String    @id @default(uuid())
  productionRunId     String
  elementName         String
  elementType         String
  qtyPerSet           Int
  totalQty            Int
  unitValue           Decimal?  @db.Decimal(12, 2)
  weightGramsPerPc    Float?
  productionDate      DateTime?
  waxCount            Int?
  czStones            Int?
  czWeight            Float?
  castingReceived     Boolean   @default(false)
  metalLotId          String?
  stoneLotId          String?
  metalWeightGrams    Float?
  rawMaterialDeducted Boolean   @default(false)
  stoneOrderDate      DateTime?
  stoneDeliveryDate   DateTime?
  stoneSignOff        String?
  sortOrder           Int       @default(0)
  motifId             String?
  imageUrl            String?   @db.Text
  stageCheckoffs      Json      @default("{}")

  productionRun ProductionRun @relation(fields: [productionRunId], references: [id], onDelete: Cascade)

  @@index([productionRunId])
}

model WorkOrder {
  id            String   @id @default(uuid())
  branchId      String
  workOrderNo   String   @unique
  orderId       String?
  assignedToId  String?
  title         String
  description   String
  status        WorkOrderStatus @default(Open)
  priority      String   @default("Normal")
  dueDate       DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch     Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  order      Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  assignedTo User?  @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([assignedToId])
  @@index([branchId])
  @@index([status])
}

model Sale {
  id            String   @id @default(uuid())
  branchId      String
  unitId        String   @unique
  itemCode      String
  productId     String
  productName   String
  sku           String
  category      String
  listPrice     Decimal @db.Decimal(12, 2)
  discount      Decimal @default(0) @db.Decimal(12, 2)
  dealPrice     Decimal @db.Decimal(12, 2)
  paymentMode   String   @default("Cash")
  paymentStatus     SalePaymentStatus @default(Completed)
  paymentRef        String?
  razorpayQrId      String?
  razorpayPaymentId String?
  cartGroupId       String?
  customerId        String?
  customerPhone String
  customerName  String?
  soldAt        DateTime @default(now())

  branch   Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  unit     InventoryUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  customer Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoice  Invoice?

  @@index([soldAt])
  @@index([branchId])
  @@index([category])
  @@index([customerPhone])
  @@index([customerId])
  @@index([productId])
  @@index([paymentStatus])
  @@index([cartGroupId])
}

model Invoice {
  id             String   @id @default(uuid())
  branchId       String
  invoiceNo      String   @unique
  saleId         String   @unique
  customerId     String?
  customerName   String
  customerMobile String
  itemCode       String
  productName    String
  sku            String
  listPrice      Decimal @db.Decimal(12, 2)
  discount       Decimal @default(0) @db.Decimal(12, 2)
  total          Decimal @db.Decimal(12, 2)
  paymentMode    String
  paymentRef     String?
  status         String   @default("Paid")
  createdAt      DateTime @default(now())

  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sale     Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([branchId])
}

model ProductImage {
  id        String @id @default(uuid())
  productId String
  url       String
  name      String
  sortOrder Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model MetalMarketRate {
  id          String   @id @default(uuid())
  metalType   String
  purity      String
  ratePerGram Decimal  @db.Decimal(12, 2)
  source      String
  fetchedAt   DateTime
  createdAt   DateTime @default(now())

  @@index([metalType, purity, fetchedAt])
}

model MetalLot {
  id           String   @id @default(uuid())
  branchId     String
  lotNumber    String   @unique
  metalType    String
  purity       String
  weightGrams  Float
  purchaseRate Decimal @db.Decimal(12, 2)
  currentRate  Decimal @db.Decimal(12, 2)
  vendor       String
  location     String   @default("Main Vault")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([metalType])
  @@index([location])
}

model CertifiedStoneLot {
  id                String   @id @default(uuid())
  branchId          String
  certificateNumber String
  stoneType         String
  carat             Float
  color             String?
  clarity           String?
  cut               String?
  vendor            String
  purchaseRate      Decimal? @db.Decimal(12, 2)
  currentRate       Decimal? @db.Decimal(12, 2)
  location          String   @default("Main Vault")
  status            CertifiedStoneLotStatus @default(InStock)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, certificateNumber])
  @@index([branchId])
  @@index([stoneType])
  @@index([location])
  @@index([status])
}

model StoneMaster {
  id              String        @id @default(uuid())
  organizationId  String
  stoneCode       String
  stoneName       String
  stoneCategory   StoneCategory
  stoneType       StoneOriginType
  stoneMaterial   String
  shape           StoneShape
  sizeMm          String
  color           String
  clarityGrade    String?
  cut             String?
  uom             StoneUOM
  unitWeightCt    Decimal?      @db.Decimal(10, 6)
  isActive        Boolean       @default(true)
  notes           String?
  createdByName   String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lots         StoneLot[]
  motifStones  MotifStone[]
  issues       ProductionRunStoneIssue[]

  @@unique([organizationId, stoneCode])
  @@index([organizationId])
  @@index([stoneCategory])
  @@index([isActive])
}

model StoneLot {
  id              String                 @id @default(uuid())
  branchId        String
  stoneMasterId   String
  lotNo           String
  packetNo        String?
  vendorStoneCode String?
  vendorName      String
  invoiceNo       String
  invoiceDate     DateTime
  qtyPurchased    Int
  weightPurchased Decimal                @db.Decimal(10, 4)
  purchaseRate    Decimal                @db.Decimal(10, 4)
  amount          Decimal                @db.Decimal(14, 2)
  gstPct          Decimal                @db.Decimal(5, 2)
  gstAmount       Decimal                @db.Decimal(12, 2)
  totalAmount     Decimal                @db.Decimal(14, 2)
  currentQty      Int
  currentWeightCt Decimal                @db.Decimal(10, 4)
  location        String?
  reorderLevel    Int?
  status          StonePurchaseLotStatus @default(Active)
  notes           String?
  createdByName   String
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  branch      Branch                    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  stoneMaster StoneMaster               @relation(fields: [stoneMasterId], references: [id], onDelete: Restrict)
  movements   StoneMovement[]
  issues      ProductionRunStoneIssue[]

  @@unique([branchId, lotNo])
  @@index([branchId])
  @@index([stoneMasterId])
  @@index([status])
}

model StoneMovement {
  id                        String            @id @default(uuid())
  branchId                  String
  stoneLotId                String
  movementType              StoneMovementType
  qty                       Int
  weightCt                  Decimal           @db.Decimal(10, 4)
  balanceQtyAfter           Int
  balanceWeightAfter        Decimal           @db.Decimal(10, 4)
  productionRunId           String?
  productionRunStoneIssueId String?
  karigarName               String?
  ratePerUnit               Decimal           @db.Decimal(10, 4)
  totalValue                Decimal           @db.Decimal(12, 2)
  reason                    String?
  notes                     String?
  performedByName           String
  createdAt                 DateTime          @default(now())

  stoneLot                StoneLot                 @relation(fields: [stoneLotId], references: [id], onDelete: Cascade)
  branch                  Branch                   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  productionRunStoneIssue ProductionRunStoneIssue? @relation(fields: [productionRunStoneIssueId], references: [id], onDelete: SetNull)

  @@index([stoneLotId])
  @@index([branchId])
  @@index([movementType])
  @@index([createdAt])
}

model ProductionRunStoneIssue {
  id              String           @id @default(uuid())
  branchId        String
  productionRunId String
  stoneLotId      String
  stoneMasterId   String
  qtyIssued       Int
  weightIssuedCt  Decimal          @db.Decimal(10, 4)
  karigarName     String
  qtyReturned     Int              @default(0)
  weightReturnedCt Decimal         @default(0) @db.Decimal(10, 4)
  qtyBroken       Int              @default(0)
  weightBrokenCt  Decimal          @default(0) @db.Decimal(10, 4)
  qtyLost         Int              @default(0)
  weightLostCt    Decimal          @default(0) @db.Decimal(10, 4)
  qtyUsed         Int              @default(0)
  weightUsedCt    Decimal          @default(0) @db.Decimal(10, 4)
  lossReason      String?
  status          StoneIssueStatus @default(Open)
  issuedByName    String
  settledByName   String?
  issuedAt        DateTime         @default(now())
  settledAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  branch        Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  productionRun ProductionRun   @relation(fields: [productionRunId], references: [id], onDelete: Cascade)
  stoneLot      StoneLot        @relation(fields: [stoneLotId], references: [id], onDelete: Restrict)
  stoneMaster   StoneMaster     @relation(fields: [stoneMasterId], references: [id], onDelete: Restrict)
  movements     StoneMovement[]

  @@index([branchId])
  @@index([productionRunId])
  @@index([stoneLotId])
  @@index([status])
}

model RawStockAuditLog {
