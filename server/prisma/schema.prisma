  productId       String?
  itemCode        String?
  action          String
  previousValue   String?
  newValue        String?
  reason          String?
  performedById   String?
  performedByName String
  createdAt       DateTime @default(now())

  @@index([entityType, entityId])
  @@index([productId])
  @@index([createdAt])
}

model SaleAuditLog {
