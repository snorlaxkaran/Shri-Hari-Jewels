{
  "name": "shri-hari-jewels-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "start:prod": "node dist/index.js",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:deploy": "tsx scripts/migrate-status-enums.ts && tsx scripts/migrate-deploy-schema.ts && prisma db push",
    "db:backfill-motif-purity": "tsx scripts/backfill-motif-purity.ts",
    "db:migrate-motif-stones": "tsx scripts/migrate-motif-stones.ts",
    "db:sync-motif-prices": "tsx scripts/sync-motif-prices.ts",
    "db:repair-inventory-weights": "tsx scripts/repair-inventory-weights.ts",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:seed-if-empty": "tsx prisma/seed-if-empty.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.43",
    "@types/pdfkit": "^0.17.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.4.1",
    "pdfkit": "^0.19.1",
    "prisma": "^6.19.3",
    "razorpay": "^2.9.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11"
  }
}
